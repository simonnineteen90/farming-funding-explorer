{% from "govuk/components/textarea/macro.njk" import govukTextarea %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/tag/macro.njk" import govukTag %}
{% from "govuk/components/checkboxes/macro.njk" import govukCheckboxes %}
{% from "govuk/components/accordion/macro.njk" import govukAccordion %}
{% from "govuk/components/header/macro.njk" import govukHeader %}
{% from "govuk/components/footer/macro.njk" import govukFooter %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}

<!DOCTYPE html>
<html lang="en" class="govuk-template govuk-template--rebranded">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ pageTitle }} - GOV.UK</title>
  <link rel="stylesheet" href="/govuk/govuk-frontend.min.css">
  <style>
    #scheme-filters .govuk-accordion__controls {
      display: none;
    }
  </style>
</head>
<body class="govuk-template__body">
  <script>
    document.body.className += ' js-enabled' + ('noModule' in HTMLScriptElement.prototype ? ' govuk-frontend-supported' : '');
  </script>

  {{ govukHeader({
    homepageUrl: "/",
    rebrand: true,
    classes: "govuk-header--full-width-border",
    serviceName: "Farming funding explorer",
    serviceUrl: "/"
  }) }}

  <div class="govuk-width-container">
    <main class="govuk-main-wrapper" id="main-content">
      <h1 class="govuk-heading-xl">Find funding for your farm</h1>

      {% if error %}
        <div class="govuk-error-summary" data-module="govuk-error-summary">
          <div role="alert">
            <h2 class="govuk-error-summary__title">There is a problem</h2>
            <div class="govuk-error-summary__body">
              <p class="govuk-body">{{ error }}</p>
            </div>
          </div>
        </div>
      {% endif %}

      {% if rateLimited %}
        <div class="govuk-warning-text">
          <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
          <strong class="govuk-warning-text__text">
            <span class="govuk-visually-hidden">Warning</span>
            You are searching too frequently. Please wait a moment and try again.
          </strong>
        </div>
      {% endif %}

      {% if errorMessage %}
        {{ govukErrorSummary({
          titleText: "There is a problem",
          errorList: [
            {
              text: errorMessage,
              href: "#search-input"
            }
          ]
        }) }}
      {% endif %}

      <form method="post" action="/search" class="govuk-!-margin-bottom-8">
        {% if errorMessage %}
          {{ govukTextarea({
            id: "search-input",
            name: "input",
            label: {
              text: "Describe your farm and what you need funding for",
              classes: "govuk-label--m"
            },
            hint: {
              text: "You can use natural language. For example: 'I have 100 acres of farm with hens and need help improving housing' or 'Mixed farm looking to plant hedgerows and improve soil health'"
            },
            errorMessage: {
              text: errorMessage
            },
            rows: 6,
            value: input
          }) }}
        {% else %}
          {{ govukTextarea({
            id: "search-input",
            name: "input",
            label: {
              text: "Describe your farm and what you need funding for",
              classes: "govuk-label--m"
            },
            hint: {
              text: "You can use natural language. For example: 'I have 100 acres of farm with hens and need help improving housing' or 'Mixed farm looking to plant hedgerows and improve soil health'"
            },
            rows: 6,
            value: input
          }) }}
        {% endif %}

        {% if filters and filters.length > 0 %}
          {% set filterContentHtml %}
            {{ govukCheckboxes({
              idPrefix: "status",
              name: "status",
              hint: {
                text: "Select one or more statuses"
              },
              items: filters
            }) }}
          {% endset %}

          {{ govukAccordion({
            id: "scheme-filters",
            rememberExpanded: false,
            items: [
              {
                heading: {
                  text: "Expand filters"
                },
                expanded: false,
                content: {
                  html: filterContentHtml
                }
              }
            ]
          }) }}
        {% endif %}

        {{ govukButton({
          text: "Search"
        }) }}
      </form>

      {% if searched and not errorMessage %}
        {% if resultCount === 0 %}
          <p class="govuk-body">No schemes found.</p>
        {% else %}
          <h2 class="govuk-heading-l">{{ resultCount }} scheme{{ 's' if resultCount !== 1 }} found</h2>

          {% if summary %}
            <p class="govuk-body">{{ summary.overallSummary }}</p>

            {% if summary.bestMatch %}
              <div class="govuk-inset-text">
                <h3 class="govuk-heading-s govuk-!-margin-bottom-1">Best match: {{ summary.bestMatch.name }}</h3>
                <p class="govuk-body govuk-!-margin-bottom-0">{{ summary.bestMatch.reason }}</p>
              </div>
            {% endif %}
          {% endif %}

          {% for scheme in schemes %}
            <section class="govuk-!-margin-bottom-6">
              <h3 class="govuk-heading-m govuk-!-margin-bottom-1">
                <a href="{{ scheme.url }}" class="govuk-link">{{ scheme.name }}</a>
              </h3>
              {{ govukTag({
                text: scheme.statusText,
                classes: scheme.statusClasses
              }) }}
              <p class="govuk-body govuk-!-margin-top-2">{{ scheme.description }}</p>
              <p class="govuk-body govuk-!-font-weight-bold">Funding: {{ scheme.funding }}</p>
              <hr class="govuk-section-break govuk-section-break--visible govuk-!-margin-bottom-2">
            </section>
          {% endfor %}
        {% endif %}
      {% endif %}
    </main>
  </div>

  {{ govukFooter({
    rebrand: true,
    meta: {
      visuallyHiddenTitle: "Prototype information",
      items: [
        {
          href: "#",
          text: "Built for a hackathon prototype"
        }
      ]
    }
  }) }}

  <script type="module">
    import { initAll } from '/govuk/govuk-frontend.min.js';

    initAll();
  </script>
</body>
</html>

{% from "govuk/components/textarea/macro.njk" import govukTextarea %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/tag/macro.njk" import govukTag %}
{% from "govuk/components/header/macro.njk" import govukHeader %}
{% from "govuk/components/footer/macro.njk" import govukFooter %}

<!DOCTYPE html>
<html lang="en" class="govuk-template govuk-template--rebranded">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ pageTitle }} - GOV.UK</title>
  <link rel="stylesheet" href="/govuk/govuk-frontend.min.css">
</head>
<body class="govuk-template__body">
  <script>document.body.className += ' js-enabled';</script>

  {{ govukHeader({
    homepageUrl: "/",
    rebrand: true,
    classes: "govuk-header--full-width-border",
    serviceName: "Farming funding explorer",
    serviceUrl: "/"
  }) }}

  <div class="govuk-width-container">
    <main class="govuk-main-wrapper" id="main-content">
      <h1 class="govuk-heading-xl">Find funding for your farm</h1>
      <p class="govuk-body">Describe what you need funding for and we will show you relevant schemes.</p>

      <form method="post" action="/search" class="govuk-!-margin-bottom-8">
        {{ govukTextarea({
          id: "search-input",
          name: "input",
          label: {
            text: "Describe your farm and what you need funding for",
            classes: "govuk-label--m"
          },
          hint: {
            text: "You can use natural language. For example: 'I have 100 acres of farm with hens and need help improving housing' or 'Mixed farm looking to plant hedgerows and improve soil health'"
          },
          rows: 6,
          value: input
        }) }}

        {{ govukButton({
          text: "Search"
        }) }}
      </form>

      {% if searched %}
        {% if resultCount === 0 %}
          <p class="govuk-body">No schemes found.</p>
        {% else %}
          <h2 class="govuk-heading-l">{{ resultCount }} schemes found</h2>

          {% for scheme in schemes %}
            <section class="govuk-!-margin-bottom-6">
              <h3 class="govuk-heading-m govuk-!-margin-bottom-1">
                <a href="{{ scheme.url }}" target="{{ scheme.linkTarget }}" rel="{{ scheme.linkRel }}" class="govuk-link">
                  {{ scheme.name }}
                  {% if scheme.linkTarget == "_blank" %}<span class="govuk-visually-hidden"> (opens in new tab)</span>{% endif %}
                </a>
              </h3>
              {{ govukTag({
                text: scheme.statusText,
                classes: scheme.statusClasses
              }) }}
              <p class="govuk-body govuk-!-margin-top-2">{{ scheme.description }}</p>
              <p class="govuk-body govuk-!-font-weight-bold">Funding: {{ scheme.funding }}</p>
              <hr class="govuk-section-break govuk-section-break--visible govuk-!-margin-bottom-2">
            </section>
          {% endfor %}
        {% endif %}
      {% endif %}
    </main>
  </div>

  {{ govukFooter({
    rebrand: true,
    meta: {
      visuallyHiddenTitle: "Prototype information",
      items: [
        {
          href: "#",
          text: "Built for a hackathon prototype"
        }
      ]
    }
  }) }}

  <script src="/govuk/govuk-frontend.min.js"></script>
  <script>
    if (window.GOVUK && window.GOVUKFrontend) {
      window.GOVUKFrontend.initAll();
    }
  </script>
</body>
</html>

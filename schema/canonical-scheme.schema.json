{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/canonical-scheme.schema.json",
  "title": "Canonical Farming Scheme",
  "type": "object",
  "required": [
    "canonicalId",
    "displayName",
    "aliases",
    "status",
    "eligibility",
    "funding",
    "keywords",
    "source"
  ],
  "properties": {
    "canonicalId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "displayName": {
      "type": "string",
      "minLength": 3
    },
    "aliases": {
      "type": "object",
      "required": ["idAliases", "nameAliases"],
      "properties": {
        "idAliases": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "uniqueItems": true
        },
        "nameAliases": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "status": {
      "type": "object",
      "required": ["currentStatus"],
      "properties": {
        "currentStatus": {
          "type": "string",
          "enum": ["open", "closed", "opening_soon", "invitation_only", "unknown"]
        },
        "openDateIso": {
          "type": ["string", "null"],
          "format": "date"
        },
        "closeDateIso": {
          "type": ["string", "null"],
          "format": "date"
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "eligibility": {
      "type": "object",
      "required": [
        "geography",
        "requiresInvitation",
        "enterpriseTypes",
        "livestockTypes",
        "landFeatures"
      ],
      "properties": {
        "geography": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["england", "scotland", "wales", "northern_ireland", "uk_wide"]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "requiresInvitation": {
          "type": "boolean"
        },
        "enterpriseTypes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["arable", "dairy", "beef", "sheep", "poultry", "mixed", "horticulture", "forestry", "other"]
          },
          "uniqueItems": true
        },
        "livestockTypes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["cattle", "sheep", "pigs", "poultry", "none", "other"]
          },
          "uniqueItems": true
        },
        "landFeatures": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["river", "wetland", "woodland", "sssi", "protected_landscape", "common_land", "moorland", "historic_site", "none", "other"]
          },
          "uniqueItems": true
        },
        "minAreaHectares": {
          "type": ["number", "null"],
          "minimum": 0
        },
        "maxAreaHectares": {
          "type": ["number", "null"],
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "funding": {
      "type": "object",
      "required": ["minGrantGbp", "maxGrantGbp"],
      "properties": {
        "minGrantGbp": {
          "type": ["number", "null"],
          "minimum": 0
        },
        "maxGrantGbp": {
          "type": ["number", "null"],
          "minimum": 0
        },
        "valueNotes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "keywords": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 5,
      "uniqueItems": true
    },
    "source": {
      "type": "object",
      "required": ["primaryUrl", "lastVerifiedAt"],
      "properties": {
        "primaryUrl": {
          "type": "string",
          "format": "uri"
        },
        "lastVerifiedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
